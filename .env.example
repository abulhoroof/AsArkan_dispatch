# Copy this file to .env and fill in the values for your own Supabase project.

# ===========================================
# Supabase (required)
# ===========================================
# Find these at: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Service role key — server-side only, NEVER expose to the client.
# Used by scripts/ and edge functions for admin operations.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===========================================
# Optional integrations
# ===========================================
# Resend (driver reassignment emails). https://resend.com/api-keys
RESEND_API_KEY=
# Sender address for outgoing emails (must be verified in Resend).
EMAIL_FROM=noreply@example.com

# Microsoft Clarity (analytics sync). Clarity dashboard → Settings → Data Export.
CLARITY_API_TOKEN=

# ===========================================
# AI assistant (dispatch-chat edge function)
# ===========================================
# Any OpenAI-compatible chat completions endpoint (OpenAI, OpenRouter, Together, etc.)
# Set these as Supabase function secrets: `supabase secrets set AI_API_KEY=...`
AI_GATEWAY_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ===========================================
# Application URLs (used by invite-user edge function)
# ===========================================
# Base URL of the deployed app, used for password reset and invite links.
APP_URL=http://localhost:8080
# Comma-separated list of allowed redirect hostnames (without scheme).
# Example: ALLOWED_REDIRECT_HOSTS=example.com,app.example.com,localhost
ALLOWED_REDIRECT_HOSTS=localhost
